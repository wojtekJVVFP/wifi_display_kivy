<WifiServer>:
    button: button1 #name from py: id from kv file, the name can be the same as id
    label: label1
    image: image
    on_size: root.reposition()
    on_pos: root.reposition()
    #reposition() ustawia poszczególne widgety, klasa wifiServer

    Image:
        id: image
        source: 'obrazy/linie.jpg'

    Button:
        id: button1
        text: 'button'

    Label:
        id: label1
        text: 'jakies pole'



